		<title>How to Recycle Nitrile, Latex, and Vinyl Sterile Gloves</title>
		<link>https://earth911.com/how-to-recycle/how-to-recycle-nitrile-latex-and-vinyl-sterile-gloves/</link>
		
		<dc:creator><![CDATA[Geneva Ratcliffe]]></dc:creator>
		<pubDate>Thu, 26 Feb 2026 08:05:22 +0000</pubDate>
