		<title>Electric buses are passing a brutal cold-weather test in Wisconsin</title>
		<link>https://grist.org/transportation/electric-buses-are-passing-a-brutal-cold-weather-test-in-wisconsin/</link>
		
		<dc:creator><![CDATA[Benton Graham]]></dc:creator>
		<pubDate>Mon, 23 Feb 2026 09:30:00 +0000</pubDate>
				<category><![CDATA[Cities]]></category>
