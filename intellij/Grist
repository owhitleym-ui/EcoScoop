		<item>
		<title>Balcony solar is taking state legislatures by storm</title>
		<link>https://grist.org/buildings/balcony-solar-is-taking-state-legislatures-by-storm/</link>
		
		<dc:creator><![CDATA[Alison F. Takemura, Canary Media]]></dc:creator>
		<pubDate>Sun, 01 Mar 2026 14:00:00 +0000</pubDate>
				<category><![CDATA[Buildings]]></category>
		<category><![CDATA[Energy]]></category>
