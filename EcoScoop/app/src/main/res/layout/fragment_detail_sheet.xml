<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#F8FBF8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="40dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/drag_handle_bg"/>

        <!-- Header: emoji + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/sheetEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:id="@+id/sheetTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#1A3D1C"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Big value -->
        <TextView
            android:id="@+id/sheetBigValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="48sp"
            android:textColor="#1A3D1C"
            android:layout_marginBottom="4dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E8E0"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"/>

        <!-- 3 stat chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/chip0"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/chip_background">

                <TextView
                    android:id="@+id/chipValue0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#1A3D1C"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/chipLabel0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#7A9E7C"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chip1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/chip_background">

                <TextView
                    android:id="@+id/chipValue1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#1A3D1C"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/chipLabel1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#7A9E7C"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/chip2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="10dp"
                android:background="@drawable/chip_background">

                <TextView
                    android:id="@+id/chipValue2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="#1A3D1C"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/chipLabel2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#7A9E7C"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Table section: hidden when there are no rows -->
        <TextView
            android:id="@+id/tableNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#7A9E7C"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:visibility="gone"/>

        <View
            android:id="@+id/tableDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E8E0"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone"/>

        <!-- Rows added programmatically -->
        <LinearLayout
            android:id="@+id/tableContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </LinearLayout>
</ScrollView>
