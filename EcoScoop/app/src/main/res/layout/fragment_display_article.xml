<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <!-- Top bar: Save (right) — back is handled by the system back button -->
    <LinearLayout
        android:id="@+id/topButtonBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal">

        <Space
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <Button
            android:id="@+id/saveButton"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Save"
            android:textColor="@color/green"/>

    </LinearLayout>

    <!-- Scrollable article body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/articleDisplayTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingMultiplier="1.1"
                android:text="@string/example_title"
                android:textSize="22sp" />

            <View
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:background="?android:attr/listDivider" />

            <ImageView
                android:id="@+id/img_header"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="?attr/colorSurfaceVariant"
                android:contentDescription="Article header image"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/articleDisplayAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/example_author"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/articleDisplayDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:fontFamily="sans-serif-medium"
                android:textSize="13sp" />

            <!-- Reactions row: like and dislike counts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="4dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/likeButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Likes: 0"
                    android:textColor="@color/green"/>

                <Button
                    android:id="@+id/dislikeButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dislikes: 0"
                    android:textColor="@color/green"/>


            </LinearLayout>

            <TextView
                android:id="@+id/articleContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="16dp"
                android:lineSpacingMultiplier="1.4"
                android:text="@string/example_body"
                android:textSize="16sp" />

            <!-- Comments section -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="12dp"
                android:background="?android:attr/listDivider" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Comments"
                android:textSize="16sp" />

            <!-- Comments get added here dynamically -->
            <LinearLayout
                android:id="@+id/commentsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:orientation="vertical" />

            <!-- Comment input row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/commentInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Write a comment..."
                    android:inputType="textMultiLine"
                    android:maxLines="3" />

                <Button
                    android:id="@+id/submitCommentButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_marginStart="8dp"
                    android:text="Post"
                    android:backgroundTint="@color/green"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#3B8F40">

        <Button
            android:id="@+id/articleFeedTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Articles"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_articles"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/dashboardTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Dashboard"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_dashboard"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/searchTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Search"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_search"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/profileTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Profile"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_profile"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />
    </LinearLayout>

</LinearLayout>
