<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <!-- Scrollable content area -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- App name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EcoScoop"
                android:textSize="32sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Your environmental news hub"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:layout_marginBottom="32dp" />

            <!-- Placeholder section: Sources -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="News Sources"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Grist"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Carbon Brief"
                android:textSize="15sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Earth911"
                android:textSize="15sp"
                android:layout_marginBottom="32dp" />

            <!-- Placeholder section: About -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="About"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EcoScoop aggregates the latest environmental and climate news from trusted sources. Browse the article feed, search by keyword, tag, or author, and save articles to your personal folders."
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="32dp" />

            <!-- Placeholder section: Stats (future feature) -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Coming Soon"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Trending articles\n• Reading history\n• Saved folder management\n• Personalized recommendations"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.4" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom nav bar — equal-width buttons via weight -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/articleFeedTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Articles" />

        <Button
            android:id="@+id/dashboardTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Dashboard" />

        <Button
            android:id="@+id/searchTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Search" />

        <Button
            android:id="@+id/profileTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Profile" />

    </LinearLayout>

</LinearLayout>
