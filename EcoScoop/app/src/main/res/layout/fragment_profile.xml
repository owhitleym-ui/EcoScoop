<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <!-- FOLDER LIST SCREEN (default) -->
    <LinearLayout
        android:id="@+id/folderListScreen"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/plant_logo"
                android:scaleType="fitCenter"
                android:contentDescription="EcoScoop"
                android:layout_marginBottom="8dp" />

            <!-- Title row with Settings button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Profile"
                    android:textSize="32sp"
                    android:fontFamily="sans-serif-medium" />

                <Button
                    android:id="@+id/settingsButton"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textColor="#3B8F40" />

            </LinearLayout>

            <TextView
                android:id="@+id/usernameLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary" />

            <!-- Activity stats row -->
            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/statRead"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Read"
                        android:textSize="11sp"
                        android:textColor="@color/green" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/statLiked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Liked"
                        android:textSize="11sp"
                        android:textColor="@color/green" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/statDisliked"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorPrimary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Disliked"
                        android:textSize="11sp"
                        android:textColor="@color/green" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="8dp"
                    android:text="My Folders"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?android:attr/listDivider" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/foldersRecyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/emptyFoldersLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="32dp"
                    android:text="No folders yet.\nSave articles to create folders."
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <!-- User comments section -->
                <LinearLayout
                    android:id="@+id/commentsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:background="?android:attr/listDivider" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="24dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="8dp"
                        android:text="Your Comments"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium" />

                    <LinearLayout
                        android:id="@+id/commentsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingBottom="16dp" />

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- FOLDER CONTENTS SCREEN (shown when a folder is opened) -->
    <LinearLayout
        android:id="@+id/folderContentsScreen"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/backToFoldersButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Folders"
                android:textColor="#3B8F40" />

            <TextView
                android:id="@+id/openFolderLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:paddingStart="8dp" />

            <TextView
                android:id="@+id/removeArticleHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Long-press to remove"
                android:textSize="11sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingEnd="8dp" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/savedArticlesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/emptyLabel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="No saved articles yet.\nTap Save on any article to add one."
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="15sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom nav bar -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#3B8F40">

        <Button
            android:id="@+id/articleFeedTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Articles"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_articles"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/dashboardTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Dashboard"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_dashboard"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/searchTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Search"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_search"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/profileTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Profile"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_profile"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

    </LinearLayout>

</LinearLayout>
