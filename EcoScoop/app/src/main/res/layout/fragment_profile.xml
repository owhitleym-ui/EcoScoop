<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your saved articles"
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary" />

    </LinearLayout>

    <!-- Section label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="8dp"
        android:text="Saved Articles"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium" />

    <!-- Saved articles list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/savedArticlesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Empty state label — shown when no articles saved -->
    <TextView
        android:id="@+id/emptyLabel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No saved articles yet.\nTap Save on any article to add one."
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="15sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#A8D5B5">

        <Button
            android:id="@+id/articleFeedTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Articles"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_articles"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/dashboardTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Dashboard"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_dashboard"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/searchTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Search"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_search"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <Button
            android:id="@+id/profileTab"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Profile"
            android:textColor="#FFFFFF"
            android:drawableTop="@drawable/ic_tab_profile"
            android:drawableTint="#FFFFFF"
            android:textSize="9sp"
            android:drawablePadding="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:backgroundTint="@null"
            android:ellipsize="none"
            android:maxLines="1"
            style="@style/Widget.AppCompat.Button.Borderless" />
    </LinearLayout>

</LinearLayout>
